{
    "name": "md-doc/filament-md-doc",
    "description": "Filament v5 plugin for editing and previewing md-doc-pipeline markdown documents",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "filament/filament": "^5.0",
        "symfony/yaml": "^7.0"
    },
    "autoload": {
        "psr-4": {
            "MdDoc\\FilamentMdDoc\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "MdDoc\\FilamentMdDoc\\MdDocServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
